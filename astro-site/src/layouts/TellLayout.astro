---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" is:inline></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,600;1,600&display=swap" rel="stylesheet" />
    <style is:global>
      body { font-family: 'Noto Sans JP', sans-serif; scroll-behavior: smooth; padding-bottom: 80px; }
      @media (min-width: 768px) { body { padding-bottom: 0; } }
      .font-serif { font-family: 'Cormorant Garamond', serif; }
      .hero-bg { background: linear-gradient(135deg, #fffcf5 0%, #fff0f5 100%); }
      .fade-in-up { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease-out, transform 0.8s ease-out; }
      .fade-in-up.is-visible { opacity: 1; transform: translateY(0); }
      #mobile-menu { transition: transform 0.3s ease-in-out, opacity 0.3s ease-in-out; }
      #mobile-menu.hidden-menu { transform: translateY(-20px); opacity: 0; pointer-events: none; }
      #mobile-menu.visible-menu { transform: translateY(0); opacity: 1; pointer-events: auto; }
      .balance-container { position: relative; height: 300px; display: flex; justify-content: center; align-items: flex-end; }
      .balance-base { width: 160px; height: 20px; background: #4b5563; border-radius: 10px 10px 0 0; z-index: 10; }
      .balance-pole { width: 12px; height: 200px; background: #4b5563; position: absolute; bottom: 0; z-index: 10; }
      .balance-arm { width: 320px; height: 8px; background: #374151; position: absolute; bottom: 190px; border-radius: 4px; transform-origin: center; transition: transform 1.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
      .plate-string { width: 2px; height: 80px; background: #9ca3af; position: absolute; top: 4px; }
      .plate { width: 100px; height: 100px; border-radius: 50%; position: absolute; top: 84px; left: -50px; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); transition: transform 1.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
      .plate-left-group { position: absolute; left: 20px; top: 0; }
      .plate-right-group { position: absolute; right: 20px; top: 0; }
      .bar-container { width: 100%; background-color: #e5e7eb; border-radius: 9999px; height: 24px; overflow: hidden; position: relative; }
      .bar-fill { height: 100%; width: 0%; border-radius: 9999px; transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1); display: flex; align-items: center; justify-content: flex-end; padding-right: 10px; white-space: nowrap; }
      .counter-value { font-feature-settings: "tnum"; font-variant-numeric: tabular-nums; }
      .primary-bg { background-color: #d4a373; }
      @keyframes spin_20s { to { transform: rotate(360deg); } }
      .animate-\[spin_20s_linear_infinite\] { animation: spin_20s 20s linear infinite; }
      .animate-\[spin_20s_linear_infinite_reverse\] { animation: spin_20s 20s linear infinite reverse; }
      @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
      .group-open\:animate-fadeIn:not(.group-open) { animation: fadeIn 0.3s ease-out; }
    </style>
  </head>
  <body class="text-gray-700 bg-white">
    <header class="fixed w-full bg-white/95 backdrop-blur-md shadow-sm z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <div class="flex items-center z-50">
            <div class="flex flex-col">
              <span class="text-xs text-gray-500 tracking-widest">小顔と美肌のクリニック</span>
              <span class="font-bold text-xl tracking-tight text-gray-800">TIAM CLINIC <span class="text-[#d4a373]">GINZA</span></span>
            </div>
          </div>
          <nav class="hidden lg:flex space-x-6 text-sm">
            <a href="#about" class="text-gray-600 hover:text-[#d4a373] transition font-medium">課題</a>
            <a href="#new-value" class="text-gray-600 hover:text-[#d4a373] transition font-medium">新価値</a>
            <a href="#quality" class="text-gray-600 hover:text-[#d4a373] transition font-medium">品質</a>
            <a href="#treatment" class="text-gray-600 hover:text-[#d4a373] transition font-medium">施術</a>
            <a href="#merit" class="text-gray-600 hover:text-[#d4a373] transition font-medium">メリット</a>
            <a href="#plan" class="text-gray-600 hover:text-[#d4a373] transition font-medium">料金</a>
            <a href="#flow" class="text-gray-600 hover:text-[#d4a373] transition font-medium">導入</a>
          </nav>
          <div class="hidden lg:block">
            <a href="#contact" class="bg-[#333] text-white px-6 py-3 rounded-full text-sm font-medium shadow-md transition transform hover:bg-gray-700">お問い合わせ</a>
          </div>
          <div class="lg:hidden z-50">
            <button id="menu-btn" class="text-gray-600 hover:text-[#d4a373] focus:outline-none p-2" aria-label="メニュー">
              <i data-lucide="menu" class="w-8 h-8" id="menu-icon"></i>
            </button>
          </div>
        </div>
      </div>
      <div id="mobile-menu" class="fixed inset-0 bg-white z-40 hidden-menu flex flex-col pt-24 px-6 pb-10 overflow-y-auto lg:hidden">
        <nav class="flex flex-col space-y-6 text-center">
          <a href="#about" class="text-xl font-bold text-gray-800 hover:text-[#d4a373] mobile-link">課題と解決</a>
          <a href="#new-value" class="text-xl font-bold text-gray-800 hover:text-[#d4a373] mobile-link">新たな価値</a>
          <a href="#quality" class="text-xl font-bold text-gray-800 hover:text-[#d4a373] mobile-link">TIAMの品質</a>
          <a href="#treatment" class="text-xl font-bold text-gray-800 hover:text-[#d4a373] mobile-link">施術内容</a>
          <a href="#merit" class="text-xl font-bold text-gray-800 hover:text-[#d4a373] mobile-link">導入メリット</a>
          <a href="#plan" class="text-xl font-bold text-gray-800 hover:text-[#d4a373] mobile-link">料金プラン</a>
          <a href="#flow" class="text-xl font-bold text-gray-800 hover:text-[#d4a373] mobile-link">導入の流れ</a>
        </nav>
        <div class="mt-8 flex flex-col gap-4">
          <a href="#contact" class="bg-[#333] text-white py-4 rounded-full text-center font-bold shadow-lg mobile-link">お問い合わせフォームへ</a>
          <a href="https://page.line.me/718awdjv" target="_blank" class="bg-[#06c755] text-white py-4 rounded-full text-center font-bold shadow-lg flex items-center justify-center">
            <i data-lucide="message-circle" class="w-5 h-5 mr-2 fill-current"></i> LINEで導入相談
          </a>
        </div>
      </div>
    </header>

    <div class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-200 z-50 lg:hidden shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
      <div class="grid grid-cols-2 h-16">
        <a href="tel:0362806007" class="flex flex-col items-center justify-center bg-gray-50 text-gray-700 active:bg-gray-200">
          <i data-lucide="phone" class="w-5 h-5 mb-1"></i>
          <span class="text-xs font-bold">電話で相談</span>
        </a>
        <a href="https://page.line.me/718awdjv" target="_blank" class="flex flex-col items-center justify-center bg-[#06c755] text-white active:bg-[#05b34c]">
          <i data-lucide="message-circle" class="w-5 h-5 mb-1 fill-current"></i>
          <span class="text-xs font-bold">LINEで導入相談</span>
        </a>
      </div>
    </div>

    <slot />

    <footer id="contact" class="bg-white pt-20 pb-10 border-t border-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">TIAM CLINIC <span class="text-[#d4a373]">GINZA</span></h2>
            <p class="text-gray-600 mb-8 leading-relaxed">美容医療を通じて、働く人々の自信と笑顔を引き出します。<br />御社の社員様に、新しい福利厚生体験を。</p>
            <div class="space-y-4">
              <div class="flex items-start">
                <i data-lucide="map-pin" class="h-5 w-5 text-gray-400 mt-1 mr-3"></i>
                <span class="text-gray-600">〒104-0061<br />東京都中央区銀座7丁目3-7 13階</span>
              </div>
              <div class="flex items-center">
                <i data-lucide="phone" class="h-5 w-5 text-gray-400 mr-3"></i>
                <span class="text-gray-600 font-bold">03-6280-6007</span>
              </div>
              <div class="flex items-center">
                <i data-lucide="globe" class="h-5 w-5 text-gray-400 mr-3"></i>
                <a href="https://tiamclinic.com/" target="_blank" class="text-gray-600 hover:text-[#d4a373] underline">https://tiamclinic.com/</a>
              </div>
            </div>
            <div class="mt-8 rounded-xl overflow-hidden shadow-sm h-64 border border-gray-200">
              <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3241.2714081095437!2d139.75794107628346!3d35.67031857259081!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60188b004e50446b%3A0x1c43140319991768!2zVElBTSBDTElOSUMgR0lOWkEg44OG44Kj44Ki44Og44Kv44Oq44OL44OD44Kv6YqA5bqn!5e0!3m2!1sja!2sjp!4v1764654222719!5m2!1sja!2sjp" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
          </div>
          <div class="bg-gray-50 p-8 rounded-2xl">
            <h3 class="text-lg font-bold text-gray-900 mb-4">お問い合わせフォーム</h3>
            <form class="space-y-4" onsubmit="event.preventDefault(); alert('デモ画面のため送信されません');">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">貴社名</label>
                <input type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#d4a373] focus:border-transparent outline-none" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">ご担当者様名</label>
                <input type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#d4a373] focus:border-transparent outline-none" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">メールアドレス</label>
                <input type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#d4a373] focus:border-transparent outline-none" />
              </div>
              <button type="submit" class="w-full primary-bg text-white py-3 rounded-lg font-bold shadow-md hover:opacity-90 transition mt-2">送信する</button>
            </form>
          </div>
        </div>
        <div class="mt-16 pt-8 border-t border-gray-100 text-center text-sm text-gray-400">&copy; 2024 TIAM CLINIC GINZA. All rights reserved.</div>
      </div>
    </footer>

    <script is:inline>
      lucide.createIcons();
      document.addEventListener('DOMContentLoaded', () => {
        const menuBtn = document.getElementById('menu-btn');
        const menuIcon = document.getElementById('menu-icon');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        let isMenuOpen = false;
        const toggleMenu = () => {
          isMenuOpen = !isMenuOpen;
          if (isMenuOpen) {
            mobileMenu.classList.remove('hidden-menu');
            mobileMenu.classList.add('visible-menu');
            menuIcon.setAttribute('data-lucide', 'x');
          } else {
            mobileMenu.classList.remove('visible-menu');
            mobileMenu.classList.add('hidden-menu');
            menuIcon.setAttribute('data-lucide', 'menu');
          }
          lucide.createIcons();
        };
        if (menuBtn) menuBtn.addEventListener('click', toggleMenu);
        mobileLinks.forEach(link => link.addEventListener('click', () => { if (isMenuOpen) toggleMenu(); }));
        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              const bars = entry.target.querySelectorAll('.bar-fill');
              bars.forEach(bar => { const w = bar.getAttribute('data-width'); if (w) setTimeout(() => bar.style.width = w, 200); });
              const balanceArm = entry.target.querySelector('#balance-arm');
              if (balanceArm) {
                const plateLeft = entry.target.querySelector('#plate-left');
                const plateRight = entry.target.querySelector('#plate-right');
                setTimeout(() => {
                  balanceArm.style.transform = 'rotate(15deg)';
                  if (plateLeft) plateLeft.style.transform = 'rotate(-15deg)';
                  if (plateRight) plateRight.style.transform = 'rotate(-15deg)';
                }, 500);
              }
              const counters = entry.target.querySelectorAll('.counter-value');
              counters.forEach(counter => {
                const target = +counter.getAttribute('data-target');
                const duration = 2000;
                const increment = target / (duration / 16);
                let current = 0;
                const update = () => {
                  current += increment;
                  counter.innerText = current < target ? Math.ceil(current).toLocaleString() : target.toLocaleString();
                  if (current < target) requestAnimationFrame(update);
                };
                update();
              });
              obs.unobserve(entry.target);
            }
          });
        }, { root: null, rootMargin: '0px', threshold: 0.2 });
        document.querySelectorAll('.fade-in-up').forEach(el => observer.observe(el));
        ['graph-trigger', 'balance-trigger', 'counter-trigger'].forEach(id => {
          const el = document.getElementById(id);
          if (el) observer.observe(el);
        });
      });
    </script>
  </body>
</html>
